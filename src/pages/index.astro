---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProductCard from "../components/ProductCard.astro";
import { categories, site } from "../lib/site";
import { getBestsellers, formatEuro } from "../lib/queries";

const bestsellers = await getBestsellers(8);
const featuredCategories = categories.slice(0, 4);
---

<BaseLayout>
  <Hero />

  <section class="py-20">
    <div class="section">
      <div class="mb-12 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <span class="text-xs font-medium uppercase tracking-wide text-rosa-500">
            Os nossos favoritos
          </span>
          <h2 class="mt-1 text-3xl font-semibold text-ink sm:text-4xl">Mais vendidos</h2>
          <p class="mt-3 max-w-lg text-sm text-ink-soft">
            As peças que os nossos clientes mais pedem. T-shirts, tote bags e bolsas personalizadas com carinho.
          </p>
        </div>
        <a href="/catalogo" class="btn-ghost self-start">
          Ver tudo
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>

      {bestsellers.length === 0 ? (
        <div class="rounded-3xl border border-dashed border-ink-line bg-rosa-50/60 p-10 text-center text-sm text-ink-soft">
          Ainda não há produtos em destaque. Marca alguns como <strong>bestseller</strong> no admin.
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {bestsellers.map((p) => (
            <ProductCard
              slug={p.slug}
              name={p.name}
              price={p.priceCents / 100}
              image={p.images[0]?.url ?? "/placeholders/product.svg"}
              category={p.category}
              bestseller={true}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="bg-rosa-50/60 py-20">
    <div class="section">
      <div class="mb-12 text-center">
        <span class="text-xs font-medium uppercase tracking-wide text-rosa-500">Explora</span>
        <h2 class="mt-1 text-3xl font-semibold text-ink sm:text-4xl">Categorias em destaque</h2>
        <p class="mt-3 mx-auto max-w-lg text-sm text-ink-soft">
          Encontra a peça ideal para personalizar ou oferecer.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
        {featuredCategories.map((c) => (
          <a
            href={`/catalogo?categoria=${c.slug}`}
            class="group flex flex-col items-center rounded-3xl border border-ink-line bg-white p-6 text-center transition hover:-translate-y-0.5 hover:border-rosa-300 hover:shadow-lg"
          >
            <div class="flex h-20 w-20 items-center justify-center rounded-full bg-rosa-100 text-2xl text-rosa-500 transition group-hover:bg-rosa-400 group-hover:text-white">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8">
                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
                <line x1="3" y1="6" x2="21" y2="6" />
                <path d="M16 10a4 4 0 0 1-8 0" />
              </svg>
            </div>
            <span class="mt-4 text-sm font-semibold text-ink">{c.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="section">
      <div class="grid gap-12 rounded-[40px] bg-ink px-8 py-16 text-white md:grid-cols-2 md:px-16">
        <div>
          <span class="text-xs font-medium uppercase tracking-wide text-rosa-300">Personalização</span>
          <h2 class="mt-2 text-3xl font-semibold leading-tight sm:text-4xl">
            A tua frase, o teu doodle,<br />a tua peça.
          </h2>
          <p class="mt-5 text-sm leading-relaxed text-white/70">
            Em cada produto podes escrever uma frase até 100 caracteres, escolher as cores e
            descrever o desenho que queres estampado. Nós fazemos o resto à mão.
          </p>
          <a
            href="/como-encomendar"
            class="mt-8 inline-flex items-center gap-2 rounded-full border border-white/20 px-6 py-3 text-sm font-medium text-white transition hover:border-rosa-300 hover:text-rosa-300"
          >
            Ver como encomendar
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>
        <ul class="grid gap-6 text-sm">
          <li class="flex items-start gap-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-rosa-500 text-xs font-semibold text-white">1</span>
            <div>
              <p class="font-semibold">Escolhe o produto</p>
              <p class="mt-1 text-white/60">T-shirt, tote bag, frasco, capa de telemóvel e mais.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-rosa-500 text-xs font-semibold text-white">2</span>
            <div>
              <p class="font-semibold">Personaliza</p>
              <p class="mt-1 text-white/60">Escreve a tua frase, escolhe cores, descreve o desenho.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-rosa-500 text-xs font-semibold text-white">3</span>
            <div>
              <p class="font-semibold">Recebe em casa</p>
              <p class="mt-1 text-white/60">{site.preparationDays}, envio via {site.shippingProvider}.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
