---
interface Props {
  data: {
    url: string;
    title: string;
    caption: string;
  };
}

const { data } = Astro.props;

function toEmbedUrl(raw: string): string {
  if (!raw) return "";
  try {
    const url = new URL(raw);
    // YouTube: youtube.com/watch?v=ID
    if (url.hostname === "www.youtube.com" || url.hostname === "youtube.com") {
      const v = url.searchParams.get("v");
      if (v) return `https://www.youtube.com/embed/${v}`;
    }
    // YouTube short: youtu.be/ID
    if (url.hostname === "youtu.be") {
      const id = url.pathname.slice(1);
      if (id) return `https://www.youtube.com/embed/${id}`;
    }
    // Vimeo: vimeo.com/ID
    if (url.hostname === "vimeo.com" || url.hostname === "www.vimeo.com") {
      const id = url.pathname.slice(1);
      if (id && /^\d+$/.test(id)) return `https://player.vimeo.com/video/${id}`;
    }
    // Already an embed URL — pass through
    return raw;
  } catch {
    return raw;
  }
}

const embedUrl = toEmbedUrl(data.url);
---

{embedUrl && (
  <section class="py-16">
    <div class="section max-w-4xl">
      {data.title && (
        <h2 class="mb-6 text-center text-2xl font-semibold text-ink sm:text-3xl">
          {data.title}
        </h2>
      )}
      <div class="relative overflow-hidden rounded-3xl" style="padding-top: 56.25%;">
        <iframe
          src={embedUrl}
          title={data.title || "Video"}
          class="absolute inset-0 h-full w-full border-0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        />
      </div>
      {data.caption && (
        <p class="mt-4 text-center text-sm text-ink-muted">{data.caption}</p>
      )}
    </div>
  </section>
)}
