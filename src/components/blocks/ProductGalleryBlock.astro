---
import type { ProductGalleryData } from "../../lib/blocks";
import type { ProductWithExtras } from "../../lib/queries";
import { isAvailable } from "../../lib/queries";
import ProductGallery from "../islands/ProductGallery.tsx";

interface Props {
  data: ProductGalleryData;
  product: ProductWithExtras;
}

const { data, product } = Astro.props;
const available = isAvailable(product);
---

<div class="flex flex-col gap-4">
  <ProductGallery
    client:load
    images={product.images.map((i) => ({ url: i.url, alt: i.alt, kind: i.kind, focalX: i.focalX, focalY: i.focalY }))}
    productName={product.name}
    showThumbs={data.showThumbs}
    showBadges={data.showBadges}
    badges={{ bestseller: product.bestseller, outOfStock: !available }}
  />
  <p class="mt-2 text-xs text-ink-muted">
    As imagens mostram exemplos reais de encomendas anteriores, para ilustrar possíveis
    estampas e designs.
  </p>
</div>
