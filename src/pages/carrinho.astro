---
import BaseLayout from "../layouts/BaseLayout.astro";
import CartView from "../components/islands/CartView.tsx";
import Slot from "../components/Slot.astro";
---

<BaseLayout title="Carrinho">
  <Slot name="carrinho-top" />

  <section class="border-b border-ink-line py-12">
    <div class="section">
      <span class="text-xs font-medium uppercase tracking-wide text-rosa-500">
        Carrinho
      </span>
      <h1 class="mt-2 text-4xl font-semibold text-ink sm:text-5xl">
        A tua seleção
      </h1>
      <p class="mt-3 max-w-2xl text-sm text-ink-soft">
        Revê os produtos e personalizações antes de avançar para o checkout.
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="section">
      <CartView client:only="react" />
    </div>
  </section>

  <Slot name="carrinho-before-checkout" />
</BaseLayout>
