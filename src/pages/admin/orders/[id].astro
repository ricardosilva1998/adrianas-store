---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import OrderActions from "../../../components/admin/OrderActions.tsx";
import { getOrderWithItems, formatEuro } from "../../../lib/queries";
import {
  STATUS_COLORS,
  STATUS_LABELS,
  VALID_TRANSITIONS,
} from "../../../lib/orders";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/admin/login");

const { id } = Astro.params;
const numericId = Number(id);
if (!Number.isFinite(numericId)) return Astro.redirect("/admin/orders");

const result = await getOrderWithItems(numericId);
if (!result) {
  return new Response("Encomenda não encontrada", { status: 404 });
}

const { order, items, events } = result;
const allowed = VALID_TRANSITIONS[order.status] ?? [];

const paymentLabels: Record<string, string> = {
  mbway: "MB Way",
  transferencia: "Transferência bancária",
  paypal: "PayPal",
};
---

<AdminLayout title={`Encomenda ${order.number}`} user={user}>
  <div class="mb-6">
    <a href="/admin/orders" class="text-xs text-ink-muted hover:text-rosa-500">
      ← Todas as encomendas
    </a>
  </div>

  <div class="grid gap-6 lg:grid-cols-[1.6fr_1fr]">
    <div class="space-y-6">
      <section class="rounded-3xl border border-ink-line bg-surface p-6">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-rosa-500">
              Encomenda #{order.number}
            </p>
            <p class="mt-1 text-xs text-ink-muted">
              Criada a {new Date(order.createdAt).toLocaleString("pt-PT")}
            </p>
          </div>
          <span
            class:list={[
              "inline-flex items-center rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-wide",
              STATUS_COLORS[order.status],
            ]}
          >
            {STATUS_LABELS[order.status]}
          </span>
        </div>

        <div class="mt-6 divide-y divide-ink-line">
          {items.map((item) => (
            <div class="flex gap-4 py-4">
              <div class="h-20 w-20 shrink-0 overflow-hidden rounded-xl bg-rosa-50">
                {item.image && <img src={item.image} alt={item.productName} class="h-full w-full object-cover" />}
              </div>
              <div class="flex-1">
                <p class="font-medium text-ink">{item.quantity}× {item.productName}</p>
                <p class="text-xs text-ink-muted">{item.productSlug}</p>
                {item.personalization && (
                  <div class="mt-2 rounded-xl bg-rosa-50/70 p-3 text-xs text-ink-soft">
                    {item.personalization.phrase && (
                      <p class="italic">"{item.personalization.phrase}"</p>
                    )}
                    {item.personalization.description && (
                      <p class="mt-1">{item.personalization.description}</p>
                    )}
                    {item.personalization.colors?.length > 0 && (
                      <div class="mt-2 flex gap-1.5">
                        {item.personalization.colors.map((hex: string) => (
                          <span
                            class="h-4 w-4 rounded-full border border-ink-line"
                            style={`background-color: ${hex}`}
                          ></span>
                        ))}
                      </div>
                    )}
                    {item.personalization.attachment && (
                      <p class="mt-2">
                        Ficheiro:
                        <a
                          href={item.personalization.attachment.url}
                          target="_blank"
                          rel="noreferrer"
                          class="ml-1 font-medium text-rosa-500 underline"
                        >
                          {item.personalization.attachment.name}
                        </a>
                        <span class="ml-1 uppercase tracking-wide text-ink-muted">
                          ({item.personalization.attachment.kind})
                        </span>
                      </p>
                    )}
                  </div>
                )}
              </div>
              <div class="text-right text-sm font-semibold text-ink">
                {formatEuro(item.unitPriceCents * item.quantity)}
              </div>
            </div>
          ))}
        </div>

        <div class="mt-4 border-t border-ink-line pt-4 text-sm">
          <div class="flex items-center justify-between">
            <span class="text-ink-soft">Subtotal</span>
            <span class="text-ink">{formatEuro(order.subtotalCents)}</span>
          </div>
          {order.couponCode && order.discountCents > 0 && (
            <div class="mt-2 flex items-center justify-between text-emerald-700">
              <span>Desconto ({order.couponCode})</span>
              <span class="font-semibold">−{formatEuro(order.discountCents)}</span>
            </div>
          )}
          <div class="mt-3 flex items-center justify-between border-t border-ink-line pt-3">
            <span class="font-semibold text-ink-soft">Total</span>
            <span class="text-xl font-semibold text-ink">{formatEuro(order.subtotalCents - (order.discountCents ?? 0))}</span>
          </div>
        </div>
      </section>

      <section class="rounded-3xl border border-ink-line bg-surface p-6">
        <h3 class="text-lg font-semibold text-ink">Histórico</h3>
        <ul class="mt-4 space-y-3">
          {events.map((e) => (
            <li class="flex items-start gap-3 text-sm">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-rosa-400"></span>
              <div class="flex-1">
                <p class="text-ink">
                  {e.fromStatus
                    ? `${STATUS_LABELS[e.fromStatus]} → `
                    : ""}
                  <strong>{STATUS_LABELS[e.toStatus]}</strong>
                </p>
                <p class="text-xs text-ink-muted">
                  {new Date(e.createdAt).toLocaleString("pt-PT")}
                  {e.note ? ` · ${e.note}` : ""}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </section>
    </div>

    <aside class="space-y-6">
      <section class="rounded-3xl border border-ink-line bg-surface p-6">
        <h3 class="text-lg font-semibold text-ink">Cliente</h3>
        <dl class="mt-4 space-y-2 text-sm">
          <div>
            <dt class="text-xs text-ink-muted">Nome</dt>
            <dd class="text-ink">{order.customerName}</dd>
          </div>
          <div>
            <dt class="text-xs text-ink-muted">Email</dt>
            <dd class="text-ink"><a href={`mailto:${order.customerEmail}`} class="hover:text-rosa-500">{order.customerEmail}</a></dd>
          </div>
          <div>
            <dt class="text-xs text-ink-muted">Telefone</dt>
            <dd class="text-ink">{order.customerPhone}</dd>
          </div>
          {order.nif && (
            <div>
              <dt class="text-xs text-ink-muted">NIF</dt>
              <dd class="text-ink">{order.nif}</dd>
            </div>
          )}
          <div>
            <dt class="text-xs text-ink-muted">Morada</dt>
            <dd class="text-ink">{order.address}<br />{order.postalCode} {order.city}</dd>
          </div>
          <div>
            <dt class="text-xs text-ink-muted">Pagamento</dt>
            <dd class="text-ink">{paymentLabels[order.paymentMethod]}</dd>
          </div>
          {order.trackingCode && (
            <div>
              <dt class="text-xs text-ink-muted">Tracking CTT</dt>
              <dd class="font-mono text-ink">{order.trackingCode}</dd>
            </div>
          )}
          {order.notes && (
            <div>
              <dt class="text-xs text-ink-muted">Notas do cliente</dt>
              <dd class="text-ink-soft">{order.notes}</dd>
            </div>
          )}
        </dl>
      </section>

      <OrderActions
        client:load
        orderId={order.id}
        currentStatus={order.status}
        currentTracking={order.trackingCode}
        allowedTransitions={allowed}
      />
    </aside>
  </div>
</AdminLayout>
