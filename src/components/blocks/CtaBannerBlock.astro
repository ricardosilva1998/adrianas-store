---
import { renderMixedContent } from "../../lib/content";

interface Props {
  data: {
    title: string;
    subtitle: string;
    buttonText: string;
    buttonUrl: string;
    bgColor: "rosa" | "ink";
    backgroundImage?: string;
    align?: "left" | "center";
  };
}

const { data } = Astro.props;
const isInk = data.bgColor === "ink";
const hasBgImage = !!data.backgroundImage;
const isCenter = data.align === "center";
const subtitleHtml = renderMixedContent(data.subtitle);
---

<section class="py-20">
  <div class="section">
    {hasBgImage ? (
      <div
        class="relative overflow-hidden rounded-[40px] bg-cover bg-center px-8 py-16 md:px-16"
        style={`background-image:url('${data.backgroundImage}')`}
      >
        <div class="absolute inset-0 rounded-[40px] bg-black/50"></div>
        <div class={`relative text-white ${isCenter ? "mx-auto text-center" : ""}`}>
          {data.title && (
            <h2 class="text-3xl font-semibold leading-tight text-white sm:text-4xl">
              {data.title}
            </h2>
          )}
          {subtitleHtml && (
            <div class={`prose prose-sm mt-5 max-w-none leading-relaxed text-white/70 prose-headings:text-white prose-strong:text-white prose-a:text-white ${isCenter ? "mx-auto max-w-xl" : "max-w-xl"}`} set:html={subtitleHtml} />
          )}
          {data.buttonText && data.buttonUrl && (
            <a
              href={data.buttonUrl}
              class="mt-8 inline-flex items-center gap-2 rounded-full border border-white/20 px-6 py-3 text-sm font-medium text-white transition hover:border-rosa-300 hover:text-rosa-300"
            >
              {data.buttonText}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                <path d="M5 12h14" />
                <path d="m12 5 7 7-7 7" />
              </svg>
            </a>
          )}
        </div>
      </div>
    ) : (
      <div class={`rounded-[40px] px-8 py-16 md:px-16 ${isInk ? "bg-ink text-white" : "bg-rosa-100 text-ink"} ${isCenter ? "text-center" : ""}`}>
        <div class={isCenter ? "mx-auto" : ""}>
          {data.title && (
            <h2 class={`text-3xl font-semibold leading-tight sm:text-4xl ${isInk ? "text-white" : "text-ink"}`}>
              {data.title}
            </h2>
          )}
          {subtitleHtml && (
            <div class={`prose prose-sm mt-5 max-w-none leading-relaxed ${isCenter ? "mx-auto max-w-xl" : "max-w-xl"} ${isInk ? "text-white/70 prose-headings:text-white prose-strong:text-white prose-a:text-white" : "text-ink-soft"}`} set:html={subtitleHtml} />
          )}
          {data.buttonText && data.buttonUrl && (
            <a
              href={data.buttonUrl}
              class={`mt-8 inline-flex items-center gap-2 rounded-full border px-6 py-3 text-sm font-medium transition ${
                isInk
                  ? "border-white/20 text-white hover:border-rosa-300 hover:text-rosa-300"
                  : "border-rosa-300 text-rosa-600 hover:bg-rosa-200"
              }`}
            >
              {data.buttonText}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                <path d="M5 12h14" />
                <path d="m12 5 7 7-7 7" />
              </svg>
            </a>
          )}
        </div>
      </div>
    )}
  </div>
</section>
