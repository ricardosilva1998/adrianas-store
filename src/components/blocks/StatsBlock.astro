---
interface Props {
  data: {
    title?: string;
    items: Array<{ value: string; label: string }>;
  };
}

const { data } = Astro.props;
const hasItems = data.items && data.items.length > 0;
const cols = Math.min(Math.max(data.items.length, 1), 4);
const desktopColsClass =
  cols === 1
    ? "md:grid-cols-1"
    : cols === 2
      ? "md:grid-cols-2"
      : cols === 3
        ? "md:grid-cols-3"
        : "md:grid-cols-4";
---

{hasItems && (
  <section class="section py-16">
    {data.title && (
      <h2 class="mb-12 text-center text-3xl font-semibold text-ink sm:text-4xl">{data.title}</h2>
    )}
    <div class={`grid grid-cols-2 gap-8 ${desktopColsClass}`}>
      {data.items.map((item) => (
        <div class="flex flex-col items-center text-center">
          <span class="text-5xl font-bold text-rosa-500">{item.value}</span>
          <span class="mt-2 text-xs uppercase tracking-wide text-ink-muted">{item.label}</span>
        </div>
      ))}
    </div>
  </section>
)}
