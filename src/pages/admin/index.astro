---
import AdminLayout from "../../layouts/AdminLayout.astro";
import DailyChart from "../../components/admin/DailyChart.tsx";
import VisitsChart from "../../components/admin/VisitsChart.tsx";
import TopVisitedBlock from "../../components/admin/TopVisitedBlock.astro";
import { getDashboardStats, formatEuro } from "../../lib/queries";
import { getVisitStats } from "../../lib/analytics";
import { getEmailStatus } from "../../lib/email";
import { getSiteConfig } from "../../lib/config-server";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/admin/login");

const stats = await getDashboardStats();
const visitStats = await getVisitStats();
const conv = visitStats.conversion30;
const convDisplay =
  conv.ratePct === null ? "—" : `${conv.ratePct.toFixed(1)}%`;
const emailStatus = getEmailStatus();
const siteConfig = await getSiteConfig();
const customNotifyEmails = siteConfig.globals.notifyEmails ?? [];
const effectiveAdminTo =
  customNotifyEmails.length > 0
    ? customNotifyEmails.join(", ")
    : (emailStatus.adminTo ?? "—");

const pendingTotal =
  stats.pending.new + stats.pending.paid + stats.pending.preparing;

const revenueDiff = stats.revenue.prevMonth
  ? ((stats.revenue.month - stats.revenue.prevMonth) /
      stats.revenue.prevMonth) *
    100
  : null;
---

<AdminLayout title="Dashboard" user={user}>
  <section
    class={`mb-6 rounded-2xl border p-4 text-sm ${
      emailStatus.configured
        ? "border-emerald-200 bg-emerald-50 text-emerald-800 dark:border-emerald-500/30 dark:bg-emerald-500/10 dark:text-emerald-200"
        : "border-amber-200 bg-amber-50 text-amber-900 dark:border-amber-500/30 dark:bg-amber-500/10 dark:text-amber-100"
    }`}
  >
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div class="min-w-0 flex-1">
        <p class="text-xs font-semibold uppercase tracking-wide">
          Notificações por email
        </p>
        <p class="mt-1 font-medium">
          {emailStatus.configured
            ? "Ativas — clientes recebem confirmação e tu recebes alerta de cada venda."
            : "Inativas — falta configurar variáveis de ambiente no Railway."}
        </p>
        {emailStatus.configured && (
          <p class="mt-1 text-xs opacity-80">
            Remetente: <strong>{emailStatus.from}</strong> · Alerta admin para:{" "}
            <strong>{effectiveAdminTo}</strong>{" "}
            <a href="/admin/globals#notifications" class="underline">editar</a>
          </p>
        )}
        {!emailStatus.configured && emailStatus.issues.length > 0 && (
          <ul class="mt-2 list-disc space-y-1 pl-5 text-xs">
            {emailStatus.issues.map((msg) => <li>{msg}</li>)}
          </ul>
        )}
      </div>
      <span
        class={`shrink-0 rounded-full px-3 py-1 text-xs font-semibold ${
          emailStatus.configured
            ? "bg-emerald-500/20 text-emerald-900 dark:text-emerald-100"
            : "bg-amber-500/20 text-amber-900 dark:text-amber-100"
        }`}
      >
        {emailStatus.configured ? "OK" : "A configurar"}
      </span>
    </div>
  </section>

  <section class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
    <a
      href="/admin/orders?status=new"
      class="group rounded-3xl border border-ink-line bg-surface p-6 transition hover:-translate-y-0.5 hover:border-rosa-300"
    >
      <p class="text-xs font-semibold uppercase tracking-wide text-rosa-500">A aguardar ação</p>
      <p class="mt-3 text-4xl font-semibold text-ink">{pendingTotal}</p>
      <div class="mt-3 flex gap-3 text-xs text-ink-muted">
        <span>Novas: <strong class="text-ink">{stats.pending.new}</strong></span>
        <span>Pagas: <strong class="text-ink">{stats.pending.paid}</strong></span>
        <span>Preparação: <strong class="text-ink">{stats.pending.preparing}</strong></span>
      </div>
    </a>

    <div class="rounded-3xl border border-ink-line bg-surface p-6">
      <p class="text-xs font-semibold uppercase tracking-wide text-rosa-500">Receita total</p>
      <p class="mt-3 text-4xl font-semibold text-ink">{formatEuro(stats.revenue.total)}</p>
      <p class="mt-3 text-xs text-ink-muted">Encomendas confirmadas</p>
    </div>

    <div class="rounded-3xl border border-ink-line bg-surface p-6">
      <p class="text-xs font-semibold uppercase tracking-wide text-rosa-500">Mês atual</p>
      <p class="mt-3 text-4xl font-semibold text-ink">{formatEuro(stats.revenue.month)}</p>
      <p class="mt-3 text-xs text-ink-muted">
        {revenueDiff === null
          ? "Sem comparação com mês anterior"
          : `${revenueDiff >= 0 ? "+" : ""}${revenueDiff.toFixed(1)}% vs. mês anterior`}
      </p>
    </div>

    <div class="rounded-3xl border border-ink-line bg-surface p-6">
      <p class="text-xs font-semibold uppercase tracking-wide text-rosa-500">Mês anterior</p>
      <p class="mt-3 text-4xl font-semibold text-ink">
        {formatEuro(stats.revenue.prevMonth)}
      </p>
      <p class="mt-3 text-xs text-ink-muted">Receita confirmada</p>
    </div>
  </section>

  <section class="mt-8 grid gap-5 lg:grid-cols-[1.4fr_1fr]">
    <DailyChart client:load data={stats.daily} />

    <div class="rounded-3xl border border-ink-line bg-surface p-6">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-rosa-500">Top 5</p>
        <h3 class="mt-1 text-lg font-semibold text-ink">Mais vendidos</h3>
      </div>
      {stats.topProducts.length === 0 ? (
        <p class="mt-6 text-sm text-ink-muted">
          Sem dados ainda — as estatísticas aparecem depois da primeira encomenda paga.
        </p>
      ) : (
        <ol class="mt-6 space-y-4">
          {stats.topProducts.map((p, idx) => (
            <li class="flex items-center gap-4">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-rosa-500 text-xs font-semibold text-white">
                {idx + 1}
              </span>
              <div class="min-w-0 flex-1">
                <a
                  href={`/admin/products`}
                  class="block truncate text-sm font-medium text-ink hover:text-rosa-500"
                >
                  {p.productName}
                </a>
                <p class="text-xs text-ink-muted">
                  {p.totalQuantity} vendidos · {formatEuro(p.totalRevenue)}
                </p>
              </div>
            </li>
          ))}
        </ol>
      )}
    </div>
  </section>

  <section class="mt-12">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-ink">Tráfego do site</h2>
      <p class="text-xs text-ink-muted">
        Visitas anónimas (sem cookies) registadas nos últimos 30 dias.
      </p>
    </header>

    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      <div class="rounded-3xl border border-ink-line bg-surface p-6">
        <p class="text-xs font-semibold uppercase tracking-wide text-rosa-500">Hoje</p>
        <p class="mt-3 text-4xl font-semibold text-ink">{visitStats.kpis.today.uniques}</p>
        <p class="mt-3 text-xs text-ink-muted">
          visitantes · <strong class="text-ink">{visitStats.kpis.today.pageviews}</strong> pageviews
        </p>
      </div>

      <div class="rounded-3xl border border-ink-line bg-surface p-6">
        <p class="text-xs font-semibold uppercase tracking-wide text-rosa-500">Últimos 7 dias</p>
        <p class="mt-3 text-4xl font-semibold text-ink">{visitStats.kpis.last7.uniques}</p>
        <p class="mt-3 text-xs text-ink-muted">
          visitantes · <strong class="text-ink">{visitStats.kpis.last7.pageviews}</strong> pageviews
        </p>
      </div>

      <div class="rounded-3xl border border-ink-line bg-surface p-6">
        <p class="text-xs font-semibold uppercase tracking-wide text-rosa-500">Últimos 30 dias</p>
        <p class="mt-3 text-4xl font-semibold text-ink">{visitStats.kpis.last30.uniques}</p>
        <p class="mt-3 text-xs text-ink-muted">
          visitantes · <strong class="text-ink">{visitStats.kpis.last30.pageviews}</strong> pageviews
        </p>
      </div>

      <div
        class="rounded-3xl border border-ink-line bg-surface p-6"
        title="Encomendas pagas ÷ visitantes únicos no período (aproximação)"
      >
        <p class="text-xs font-semibold uppercase tracking-wide text-rosa-500">
          Taxa de conversão (30d)
        </p>
        <p class="mt-3 text-4xl font-semibold text-ink">{convDisplay}</p>
        <p class="mt-3 text-xs text-ink-muted">
          {conv.paidOrders} encomendas · {conv.uniques} visitantes
        </p>
      </div>
    </div>

    <div class="mt-5 grid gap-5 lg:grid-cols-[1.4fr_1fr]">
      <VisitsChart client:load data={visitStats.daily30} />
      <TopVisitedBlock
        topProducts={visitStats.topProducts30}
        topPages={visitStats.topPages30}
      />
    </div>
  </section>
</AdminLayout>
