---
import CartIcon from "./islands/CartIcon.tsx";
import type { SiteConfig } from "../lib/config";

interface Props {
  config: SiteConfig;
}

const { config } = Astro.props;
const { identity, nav, banner } = config.globals;
const { logo } = config.theme;
const customer = Astro.locals.customer;
const accountInitial = customer?.name?.trim().charAt(0).toUpperCase() || "";

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);

const bannerBg = banner.bgColor === "rosa" ? "bg-rosa-400 text-white" : "bg-ink text-white";
---

{banner.enabled && banner.text && (
  <div class={`${bannerBg} text-center text-xs font-medium px-4 py-2 site-announce`}>
    {banner.linkUrl ? (
      <a href={banner.linkUrl} class="underline underline-offset-2">{banner.text}</a>
    ) : (
      <span>{banner.text}</span>
    )}
  </div>
)}

<header
  id="site-header"
  data-scrolled="false"
  class="site-header fixed inset-x-0 top-0 z-50 transition-[background-color,border-color,color] duration-200"
>
  <div class="section flex h-24 items-center justify-between gap-6 md:h-28">
    <a href="/" class="site-header__brand flex items-center gap-3" aria-label={identity.name}>
      {logo.url ? (
        <img src={logo.url} alt={logo.alt} class="h-16 w-auto md:h-20" />
      ) : (
        <span class="text-xl font-semibold tracking-tight md:text-2xl">{identity.name}</span>
      )}
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Navegação principal">
      {nav.map((link) => (
        <a
          href={link.href}
          data-active={isActive(link.href) ? "true" : "false"}
          class="site-header__link rounded-full px-4 py-2 text-sm font-medium transition"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/conta"
        aria-label={customer ? `Conta de ${customer.name}` : "Entrar / Criar conta"}
        title={customer ? customer.name : "Entrar / Criar conta"}
        class="site-header__icon-btn group relative inline-flex h-11 w-11 items-center justify-center rounded-full transition"
      >
        {customer ? (
          <span class="flex h-7 w-7 items-center justify-center rounded-full bg-rosa-500 text-xs font-semibold text-white">
            {accountInitial}
          </span>
        ) : (
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
            aria-hidden="true"
          >
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
            <circle cx="12" cy="7" r="4" />
          </svg>
        )}
      </a>
      <CartIcon client:load />
    </div>
  </div>

  <div class="md:hidden">
    <nav class="section flex items-center gap-1 overflow-x-auto pb-3 pt-1" aria-label="Navegação mobile">
      {nav.map((link) => (
        <a
          href={link.href}
          data-active={isActive(link.href) ? "true" : "false"}
          class="site-header__link shrink-0 rounded-full px-4 py-2 text-sm font-medium transition"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    color: white;
    background-color: transparent;
    border-bottom: 1px solid transparent;
  }
  .site-header[data-scrolled="true"] {
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom-color: var(--color-ink-line);
    color: var(--color-ink);
  }

  .site-header .site-header__brand {
    color: inherit;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.35);
  }
  .site-header[data-scrolled="true"] .site-header__brand {
    text-shadow: none;
  }

  .site-header .site-header__link {
    color: inherit;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.35);
  }
  .site-header[data-scrolled="true"] .site-header__link {
    text-shadow: none;
  }
  .site-header .site-header__link:hover {
    background-color: rgba(255, 255, 255, 0.18);
  }
  .site-header[data-scrolled="true"] .site-header__link:hover {
    background-color: var(--color-rosa-50);
    color: var(--color-rosa-500);
  }
  .site-header .site-header__link[data-active="true"] {
    background-color: rgba(255, 255, 255, 0.22);
  }
  .site-header[data-scrolled="true"] .site-header__link[data-active="true"] {
    background-color: var(--color-rosa-50);
    color: var(--color-rosa-500);
  }

  .site-header .site-header__icon-btn {
    border: 1px solid rgba(255, 255, 255, 0.5);
    background-color: rgba(255, 255, 255, 0.12);
    color: white;
    backdrop-filter: blur(4px);
  }
  .site-header[data-scrolled="true"] .site-header__icon-btn {
    border-color: var(--color-ink-line);
    background-color: transparent;
    color: var(--color-ink);
    backdrop-filter: none;
  }
  .site-header[data-scrolled="true"] .site-header__icon-btn:hover {
    border-color: var(--color-rosa-400);
    color: var(--color-rosa-500);
  }
  .site-header:not([data-scrolled="true"]) .site-header__icon-btn:hover {
    background-color: rgba(255, 255, 255, 0.25);
  }
</style>

<script is:inline>
  (function () {
    const header = document.getElementById("site-header");
    if (!header) return;
    const update = () => {
      header.dataset.scrolled = window.scrollY > 8 ? "true" : "false";
    };
    update();
    window.addEventListener("scroll", update, { passive: true });
  })();
</script>
