---
import Icon from "./Icon.astro";
import type { IconName } from "../../lib/icons";
import { renderMixedContent } from "../../lib/content";

interface Props {
  data: {
    title?: string;
    subtitle?: string;
    items: Array<{ icon: IconName; title: string; description: string }>;
  };
}

const { data } = Astro.props;
const hasItems = data.items && data.items.length > 0;
const items = (data.items ?? []).map((item) => ({
  ...item,
  descriptionHtml: renderMixedContent(item.description),
}));
---

{hasItems && (
<section class="section py-16">
  {(data.title || data.subtitle) && (
    <div class="mb-12 text-center">
      {data.title && (
        <h2 class="text-3xl font-semibold text-ink sm:text-4xl">{data.title}</h2>
      )}
      {data.subtitle && (
        <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-ink-soft">{data.subtitle}</p>
      )}
    </div>
  )}
  <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
    {items.map((item) => (
      <div class="flex flex-col items-start gap-4">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-rosa-50">
          <Icon name={item.icon} class="h-10 w-10 text-rosa-500" />
        </div>
        <div>
          <h3 class="text-base font-semibold text-ink">{item.title}</h3>
          {item.descriptionHtml && (
            <div class="prose prose-sm mt-2 max-w-none leading-relaxed text-ink-soft" set:html={item.descriptionHtml} />
          )}
        </div>
      </div>
    ))}
  </div>
</section>
)}
