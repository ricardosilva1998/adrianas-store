---
import BaseLayout from "../layouts/BaseLayout.astro";
import CheckoutForm from "../components/islands/CheckoutForm.tsx";
import Slot from "../components/Slot.astro";
import { db, schema } from "../db/client";
import { eq } from "drizzle-orm";

const customer = Astro.locals.customer;
let initial: {
  name: string;
  email: string;
  phone: string;
  address: string;
  postalCode: string;
  city: string;
  nif: string;
} | undefined;

if (customer) {
  const [row] = await db
    .select()
    .from(schema.customers)
    .where(eq(schema.customers.id, customer.id))
    .limit(1);
  if (row) {
    initial = {
      name: row.name,
      email: row.email,
      phone: row.phone,
      address: row.address,
      postalCode: row.postalCode,
      city: row.city,
      nif: row.nif ?? "",
    };
  }
}
---

<BaseLayout title="Checkout">
  <Slot name="checkout-top" />

  <section class="border-b border-ink-line py-12">
    <div class="section">
      <span class="text-xs font-medium uppercase tracking-wide text-rosa-500">
        Finalizar
      </span>
      <h1 class="mt-2 text-4xl font-semibold text-ink sm:text-5xl">
        Confirmar encomenda
      </h1>
      <p class="mt-3 max-w-2xl text-sm text-ink-soft">
        Preenche os teus dados. Após submeteres, recebes por email as instruções de pagamento.
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="section">
      <CheckoutForm client:only="react" initial={initial} />
    </div>
  </section>
</BaseLayout>
