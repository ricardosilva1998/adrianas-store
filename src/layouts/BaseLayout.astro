---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { renderThemeCSS, renderGoogleFontsHref } from "../lib/config";
import { getSiteConfig } from "../lib/config-server";
import { stripHtml } from "../lib/content";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const config = await getSiteConfig(Astro.locals.previewConfig);
const { identity } = config.globals;
const favicon = config.theme.favicon ?? { url: null };
const browserTitle = config.theme.browserTitle ?? "";

const {
  title,
  description = stripHtml(identity.description),
  image,
  noindex = false,
  canonical,
  jsonLd,
} = Astro.props;
const siteName = browserTitle.trim() || identity.name;
const pageTitle = title ? `${title} — ${siteName}` : `${siteName} — ${identity.tagline}`;

const themeCSS = renderThemeCSS(config.theme);
const fontsHref = renderGoogleFontsHref(config.theme.fonts);
const isPreview = Astro.url.searchParams.has("preview");

// Always derive the canonical from the configured `site` (astro.config.mjs).
// `Astro.url.origin` resolves to the Node server bind (e.g. localhost:3000
// behind Railway's proxy), which would point crawlers at the wrong host.
const publicOrigin = (Astro.site?.origin ?? Astro.url.origin).replace(/\/$/, "");
const canonicalUrl = canonical ?? `${publicOrigin}${Astro.url.pathname}`;
const ogImage = image ?? (config.theme.logo.url || null);
const jsonLdList = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const googleSiteVerification = process.env.GOOGLE_SITE_VERIFICATION;
---

<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="utf-8" />
    {favicon.url ? (
      <link rel="icon" href={favicon.url} />
    ) : (
      <>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
      </>
    )}
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content={config.theme.colors.primary} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {googleSiteVerification && (
      <meta name="google-site-verification" content={googleSiteVerification} />
    )}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={identity.name} />
    <meta property="og:locale" content="pt_PT" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontsHref} rel="stylesheet" />
    <style set:html={themeCSS}></style>
    {jsonLdList.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}
    <title>{pageTitle}</title>
  </head>
  <body class="flex min-h-dvh flex-col overflow-x-clip bg-white text-ink antialiased">
    <Header config={config} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer config={config} />

    {isPreview && (
      <script is:inline>
        // Live preview listener: parent admin editor can postMessage CSS/font
        // updates so color changes feel instant without iframe reload.
        window.addEventListener("message", (ev) => {
          // Only accept messages from same-origin senders. The preview-theme-css branch
          // writes into <style>.textContent, so allowing cross-origin here would be XSS.
          if (ev.origin !== window.location.origin) return;
          if (!ev?.data?.kind) return;

          if (ev.data.kind === "preview-theme-css") {
            const style = document.getElementById("preview-theme-css") ||
              (() => {
                const s = document.createElement("style");
                s.id = "preview-theme-css";
                document.head.appendChild(s);
                return s;
              })();
            style.textContent = ev.data.css;

            if (ev.data.fontsHref) {
              const link = document.getElementById("preview-fonts-link");
              if (link) {
                link.setAttribute("href", ev.data.fontsHref);
              } else {
                const l = document.createElement("link");
                l.id = "preview-fonts-link";
                l.rel = "stylesheet";
                l.href = ev.data.fontsHref;
                document.head.appendChild(l);
              }
            }
          } else if (ev.data.kind === "scroll-to-block" && typeof ev.data.id === "string") {
            const el = document.querySelector(`[data-block-id="${CSS.escape(ev.data.id)}"]`);
            if (el) {
              el.scrollIntoView({ behavior: "smooth", block: "start" });
              const accent = getComputedStyle(document.documentElement).getPropertyValue("--color-primary").trim() || "#ED7396";
              el.animate(
                [
                  { outline: `2px solid ${accent}`, outlineOffset: "4px" },
                  { outline: "2px solid transparent", outlineOffset: "4px" }
                ],
                { duration: 800 }
              );
            }
          } else if (ev.data.kind === "page-preview-reload") {
            window.location.reload();
          }
        });
      </script>
    )}
  </body>
</html>
