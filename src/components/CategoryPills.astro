---
import { categories } from "../lib/site";

interface Props {
  active?: string;
}

const { active } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  <a
    href="/catalogo"
    class:list={[
      "pill",
      !active ? "pill-active" : "",
    ]}
  >
    Todos
  </a>
  {categories.map((c) => (
    <a
      href={`/catalogo?categoria=${c.slug}`}
      class:list={[
        "pill",
        active === c.slug ? "pill-active" : "",
      ]}
    >
      {c.label}
    </a>
  ))}
</div>
