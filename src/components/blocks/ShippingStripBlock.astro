---
import Icon from "./Icon.astro";
import type { IconName } from "../../lib/icons";

interface Props {
  data: {
    items: Array<{ icon: IconName; title: string; subtitle?: string }>;
  };
}

const { data } = Astro.props;
const hasItems = data.items && data.items.length > 0;
const cols = Math.min(Math.max(data.items.length, 1), 4);
const desktopColsClass =
  cols === 1
    ? "md:grid-cols-1"
    : cols === 2
      ? "md:grid-cols-2"
      : cols === 3
        ? "md:grid-cols-3"
        : "md:grid-cols-4";
---

{hasItems && (
  <section class="section py-10 md:py-12">
    <div class={`grid grid-cols-1 gap-6 sm:grid-cols-2 ${desktopColsClass}`}>
      {data.items.map((item) => (
        <div class="flex items-center gap-4">
          <Icon name={item.icon} class="h-9 w-9 shrink-0 text-rosa-500 sm:h-10 sm:w-10" />
          <div>
            <p class="text-base font-semibold text-ink sm:text-lg">{item.title}</p>
            {item.subtitle && (
              <p class="text-sm text-ink-muted">{item.subtitle}</p>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
)}
