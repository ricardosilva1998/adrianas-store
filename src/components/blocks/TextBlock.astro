---
import { renderBlockContent } from "../../lib/content";

interface Props {
  data: { html?: string; markdown?: string };
}

const { data } = Astro.props;
const html = renderBlockContent({ html: data.html, markdown: data.markdown });
---

{html && (
  <section class="py-16">
    <div class="section max-w-3xl">
      <article class="prose prose-sm max-w-none text-ink-soft sm:prose-base" set:html={html} />
    </div>
  </section>
)}
