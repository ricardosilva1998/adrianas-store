---
import BaseLayout from "../layouts/BaseLayout.astro";
import AccountForm from "../components/islands/AccountForm";
import AccountDashboard from "../components/islands/AccountDashboard";
import { db, schema } from "../db/client";
import { eq, desc } from "drizzle-orm";

const customer = Astro.locals.customer;

let profile: {
  id: number;
  email: string;
  name: string;
  phone: string;
  address: string;
  postalCode: string;
  city: string;
  nif: string | null;
} | null = null;

let orders: Array<{
  id: number;
  number: string;
  status: string;
  subtotalCents: number;
  discountCents: number;
  createdAt: string;
}> = [];

if (customer) {
  const [row] = await db
    .select()
    .from(schema.customers)
    .where(eq(schema.customers.id, customer.id))
    .limit(1);
  if (row) {
    profile = {
      id: row.id,
      email: row.email,
      name: row.name,
      phone: row.phone,
      address: row.address,
      postalCode: row.postalCode,
      city: row.city,
      nif: row.nif,
    };

    const orderRows = await db
      .select({
        id: schema.orders.id,
        number: schema.orders.number,
        status: schema.orders.status,
        subtotalCents: schema.orders.subtotalCents,
        discountCents: schema.orders.discountCents,
        createdAt: schema.orders.createdAt,
      })
      .from(schema.orders)
      .where(eq(schema.orders.customerEmail, row.email))
      .orderBy(desc(schema.orders.createdAt))
      .limit(50);
    orders = orderRows.map((o) => ({
      ...o,
      createdAt: o.createdAt.toISOString(),
    }));
  }
}
---

<BaseLayout title="A minha conta" noindex>
  <section class="section py-16">
    {profile ? (
      <>
        <div class="mb-8">
          <h1 class="text-3xl font-semibold text-ink">Olá, {profile.name.split(" ")[0]}</h1>
          <p class="mt-1 text-sm text-ink-soft">Aqui podes editar os teus dados e ver as tuas encomendas.</p>
        </div>
        <AccountDashboard client:load customer={profile} orders={orders} />
      </>
    ) : (
      <>
        <div class="mb-8 text-center">
          <h1 class="text-3xl font-semibold text-ink">A minha conta</h1>
          <p class="mt-1 text-sm text-ink-soft">Entra na tua conta ou cria uma nova.</p>
        </div>
        <AccountForm client:load />
      </>
    )}
  </section>
</BaseLayout>
