---
import { renderMixedContent } from "../../lib/content";
import TestimonialsCarousel from "../islands/TestimonialsCarousel";

interface TestimonialItem {
  name: string;
  quote: string;
  avatarUrl: string;
}

interface Props {
  data: {
    title: string;
    items: TestimonialItem[];
  };
}

const { data } = Astro.props;
const hasContent = data.items && data.items.length > 0;
const items = (data.items ?? []).map((item) => ({
  name: item.name,
  avatarUrl: item.avatarUrl,
  quoteHtml: renderMixedContent(item.quote),
}));
---

{hasContent && (
  <section class="py-16">
    <div class="section">
      {data.title && (
        <h2 class="mb-10 text-center text-2xl font-semibold text-ink sm:text-3xl">
          {data.title}
        </h2>
      )}
      <TestimonialsCarousel client:load items={items} />
    </div>
  </section>
)}
