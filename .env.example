# ===== Database (Railway Postgres) =====
DATABASE_URL=postgresql://user:pass@host:port/dbname
DATABASE_PUBLIC_URL=postgresql://user:pass@host:port/dbname

# ===== Auth =====
# Min 32 caracteres. Gera com: openssl rand -base64 48
JWT_SECRET=replace-with-long-random-string-at-least-32-chars

# Seed inicial do admin (correr scripts/seed.ts)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me
ADMIN_SEED_NAME=Admin

# ===== Emails (Resend) =====
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Adriana's Store <ola@adrianastore.pt>
ADMIN_NOTIFY_EMAIL=ricardomrbs1998@gmail.com

# ===== Cloudflare R2 (uploads de imagens de produtos) =====
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET=adrianas-store
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ===== Server =====
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
