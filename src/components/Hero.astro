---
import { site } from "../lib/site";
---

<section class="relative overflow-hidden bg-white">
  <div class="absolute inset-0">
    <div class="absolute -left-24 top-1/2 h-80 w-80 -translate-y-1/2 rounded-full bg-rosa-200 opacity-50 blur-3xl"></div>
    <div class="absolute -right-32 top-16 h-96 w-96 rounded-full bg-rosa-100 opacity-60 blur-3xl"></div>
  </div>

  <div class="section relative grid gap-12 py-20 md:grid-cols-2 md:py-28 lg:py-32">
    <div class="flex flex-col justify-center">
      <span class="inline-flex w-fit items-center gap-2 rounded-full bg-rosa-50 px-4 py-1.5 text-xs font-medium uppercase tracking-wide text-rosa-500">
        <span class="h-1.5 w-1.5 rounded-full bg-rosa-500"></span>
        Novas encomendas abertas
      </span>

      <h1 class="mt-5 text-4xl font-semibold leading-tight tracking-tight text-ink sm:text-5xl lg:text-6xl">
        Peças únicas,<br />
        <span class="text-rosa-500">feitas para ti.</span>
      </h1>

      <p class="mt-6 max-w-lg text-base leading-relaxed text-ink-soft sm:text-lg">
        {site.tagline}. T-shirts, tote bags, bolsas e acessórios personalizados à mão no nosso atelier em Portugal.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href="/catalogo" class="btn-primary">
          Ver catálogo
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
        <a href="/como-encomendar" class="btn-secondary">Como encomendar</a>
      </div>

      <dl class="mt-12 grid grid-cols-3 gap-6 border-t border-ink-line pt-8 text-sm">
        <div>
          <dt class="text-xs uppercase tracking-wide text-ink-muted">Preparação</dt>
          <dd class="mt-1 font-semibold text-ink">{site.preparationDays}</dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-wide text-ink-muted">Envios</dt>
          <dd class="mt-1 font-semibold text-ink">{site.shippingProvider}</dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-wide text-ink-muted">Feito em</dt>
          <dd class="mt-1 font-semibold text-ink">Portugal</dd>
        </div>
      </dl>
    </div>

    <div class="relative hidden md:block">
      <div class="relative mx-auto aspect-[4/5] w-full max-w-lg">
        <div class="absolute inset-0 rounded-[40px] bg-rosa-100"></div>
        <div class="absolute inset-6 overflow-hidden rounded-[32px] border-8 border-white bg-white shadow-2xl">
          <img
            src="/placeholders/product.svg"
            alt="Produto em destaque"
            class="h-full w-full object-cover"
          />
        </div>
        <div class="absolute -bottom-6 -left-6 w-44 rotate-[-6deg] overflow-hidden rounded-2xl border-4 border-white bg-white shadow-xl">
          <img
            src="/placeholders/product-2.svg"
            alt="Produto em destaque"
            class="h-32 w-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>
