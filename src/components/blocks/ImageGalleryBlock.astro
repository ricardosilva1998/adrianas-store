---
import { focalToCss } from "../../lib/focal-point";

interface Props {
  data: { images: Array<{ url: string; alt: string; focal?: { x: number; y: number } }> };
}

const { data } = Astro.props;
---

{data.images.length > 0 && (
  <section class="py-16">
    <div class="section">
      <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
        {data.images.map((img) => (
          <div class="aspect-square overflow-hidden rounded-2xl bg-rosa-50">
            <img
              src={img.url}
              alt={img.alt}
              loading="lazy"
              class="h-full w-full object-cover"
              style={`object-position: ${focalToCss(img.focal)};`}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
)}
