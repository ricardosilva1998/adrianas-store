---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPage } from "../lib/queries";
import { marked } from "marked";

const page = await getPage("termos-condicoes");
const body = page ? marked.parse(page.body, { async: false }) : "";
---

<BaseLayout title={page?.title ?? "Termos e Condições"}>
  <section class="border-b border-ink-line py-16">
    <div class="section">
      <span class="text-xs font-medium uppercase tracking-wide text-rosa-500">Legal</span>
      <h1 class="mt-2 text-4xl font-semibold text-ink sm:text-5xl">
        {page?.title ?? "Termos e Condições"}
      </h1>
    </div>
  </section>

  <section class="py-16">
    <div class="section max-w-3xl">
      <article class="prose prose-sm max-w-none text-ink-soft sm:prose-base" set:html={body} />
    </div>
  </section>
</BaseLayout>
