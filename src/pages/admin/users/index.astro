---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import UsersManager from "../../../components/admin/UsersManager.tsx";
import { db, schema } from "../../../db/client";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/admin/login");
if (user.role !== "admin") return Astro.redirect("/admin");

const rows = await db
  .select({
    id: schema.users.id,
    email: schema.users.email,
    name: schema.users.name,
    role: schema.users.role,
  })
  .from(schema.users);
---

<AdminLayout title="Utilizadores" user={user}>
  <p class="text-sm text-ink-soft">
    Gere a equipa com acesso ao admin. Administradores podem criar e apagar
    utilizadores; editores só podem gerir produtos, encomendas e páginas.
  </p>

  <div class="mt-6">
    <UsersManager client:load users={rows} currentUserId={user.id} />
  </div>
</AdminLayout>
