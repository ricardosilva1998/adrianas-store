---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ResetPasswordForm from "../../components/islands/ResetPasswordForm";

const token = Astro.url.searchParams.get("token") ?? "";
---

<BaseLayout title="Repor palavra-passe" noindex>
  <section class="section py-16">
    <div class="mb-8 text-center">
      <h1 class="text-3xl font-semibold text-ink">Repor palavra-passe</h1>
      <p class="mt-1 text-sm text-ink-soft">
        Define uma nova palavra-passe para a tua conta.
      </p>
    </div>
    <ResetPasswordForm client:load token={token} />
  </section>
</BaseLayout>
